{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) 直接启动APP",
            "type": "cppvsdbg", 
            "request": "launch",
            "program": "${workspaceFolder}/sys_env/${config:build_type}/bin/app.exe",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/sys_env/${config:build_type}/bin",
            // 终端
            "console": "integratedTerminal",  /* integratedTerminal 嵌入vsocde */
            /* externalTerminal 脱离vsocde的终端，方便拖拽调试 */
        },
        {
            "name": "(Windows) 启动APP",
            "preLaunchTask": "build_program", //先去跑一下 build_program
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/sys_env/${config:build_type}/bin/app.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/sys_env/${config:build_type}/bin",
            // 终端
            "console": "integratedTerminal",  /* integratedTerminal 嵌入vsocde */
            /* externalTerminal 脱离vsocde的终端，方便拖拽调试 */
        },
    ]
}